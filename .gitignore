# LLM specs
specs/

# Script fonts: ship only the free (commercial-use) Astagina webfont; keep any
# other local trial fonts (.otf/.ttf/.woff2) in this dir out of the package.
src/django_resume/static/django_resume/fonts/script/*
!src/django_resume/static/django_resume/fonts/script/AstaginaSignature.woff2
