# virtualenv
.venv

# dist / build
dist
django_resume.egg-info

# pycharm
.idea

# Python bytecode
__pycache__/
*.pyc

# coverage
.coverage

# Databases
tests/test_database.sqlite3
example/db.sqlite3

# Javascript
node_modules/

